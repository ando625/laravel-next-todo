


# ただし .env.example はあげてOK
# .env.example   ← このコメントアウトはしない

# ========================================
# 秘密ファイル（絶対にGitHubに上げない！）
# ========================================
.env
laravel/.env
frontend/.env.local
python/.env

# ========================================
# DBのデータ（重いし個人環境のデータ）
# ========================================
docker/mysql/data/

# ========================================
# Node.js関連（npm installで再生成できる）
# ========================================
frontend/node_modules/
frontend/.next/
frontend/.turbo/

# ========================================
# Laravel関連（composer installで再生成できる）
# ========================================
laravel/vendor/
laravel/storage/logs/*.log

laravel/bootstrap/cache/*.php


# ========================================
# OS・エディタが自動生成するファイル
# ========================================
.DS_Store        # Macが自動生成するゴミファイル
.vscode/
.idea/